{% comment %}
  Products as Variants (Complementary Products as Color Swatches)
  Simple stable version:
  - current product + complementary products
  - hover updates label
  - white swatches visible
  - handles the common 2-color case cleanly
{% endcomment %}

<product-recommendations
  class="product-variants-complementary"
  data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ block.settings.product_list_limit }}&intent=complementary"
>
  {%- assign current_color_raw = product.metafields.custom.product_color -%}
  {%- assign current_color = '' -%}
  {%- assign current_color_label = '' -%}
  {%- assign label_id = 'product-variants-color-label-' | append: section.id | append: '-' | append: block.id -%}

  {% if current_color_raw %}
    {% assign v = current_color_raw.value %}
    {% if v.color %}
      {% assign current_color = v.color %}
    {% endif %}
    {% if v.label %}
      {% assign current_color_label = v.label %}
    {% elsif v.handle %}
      {% assign current_color_label = v.handle %}
    {% endif %}
  {% endif %}

  {% if current_color != blank %}
    {%- assign first_rec = recommendations.products.first -%}
    {%- assign rec_color = '' -%}
    {%- assign rec_color_label = '' -%}
    {%- assign rec_url = '' -%}
    {%- assign rec_title = '' -%}

    {% if recommendations.performed and recommendations.products_count > 0 and first_rec and first_rec.id != product.id %}
      {%- assign rec_color_raw = first_rec.metafields.custom.product_color -%}
      {% if rec_color_raw %}
        {% assign rv = rec_color_raw.value %}
        {% if rv.color %}
          {% assign rec_color = rv.color %}
        {% endif %}
        {% if rv.label %}
          {% assign rec_color_label = rv.label %}
        {% elsif rv.handle %}
          {% assign rec_color_label = rv.handle %}
        {% endif %}
      {% endif %}
      {% assign rec_url = first_rec.url %}
      {% assign rec_title = first_rec.title %}
    {% endif %}

    <div class="product-variants-complementary__inner" {{ block.shopify_attributes }}>
      <p class="product-variants-complementary__label">
        {{ block.settings.heading }}:
        <span
          id="{{ label_id }}"
          class="product-variants-complementary__label-value"
          data-default-label="{{ current_color_label | default: 'Select' | escape }}"
        >
          {{ current_color_label | default: 'Select' }}
        </span>
      </p>

      <ul class="product-variants-complementary__list is-hidden" role="list">
        {% if rec_color != blank and rec_color_label != blank and rec_color_label < current_color_label %}
          <li>
            <a
              href="{{ rec_url }}"
              class="variant-swatch"
              data-color-label="{{ rec_color_label | escape }}"
              aria-label="{{ rec_title }} — {{ rec_color_label | escape }}"
              onmouseenter="document.getElementById('{{ label_id }}').textContent = this.dataset.colorLabel;"
              onmouseleave="document.getElementById('{{ label_id }}').textContent = document.getElementById('{{ label_id }}').dataset.defaultLabel;"
              onfocus="document.getElementById('{{ label_id }}').textContent = this.dataset.colorLabel;"
              onblur="document.getElementById('{{ label_id }}').textContent = document.getElementById('{{ label_id }}').dataset.defaultLabel;"
            >
              <span
                class="variant-swatch__color"
                style="background-color: {{ rec_color | strip | escape }};"
              ></span>
            </a>
          </li>
        {% endif %}

        <li>
          <div
            class="variant-swatch variant-swatch--active"
            aria-label="{{ product.title }} — {{ current_color_label | default: 'Current color' | escape }}"
          >
            <span
              class="variant-swatch__color"
              style="background-color: {{ current_color | strip | escape }};"
            ></span>
          </div>
        </li>

        {% if rec_color != blank and rec_color_label != blank and rec_color_label >= current_color_label %}
          <li>
            <a
              href="{{ rec_url }}"
              class="variant-swatch"
              data-color-label="{{ rec_color_label | escape }}"
              aria-label="{{ rec_title }} — {{ rec_color_label | escape }}"
              onmouseenter="document.getElementById('{{ label_id }}').textContent = this.dataset.colorLabel;"
              onmouseleave="document.getElementById('{{ label_id }}').textContent = document.getElementById('{{ label_id }}').dataset.defaultLabel;"
              onfocus="document.getElementById('{{ label_id }}').textContent = this.dataset.colorLabel;"
              onblur="document.getElementById('{{ label_id }}').textContent = document.getElementById('{{ label_id }}').dataset.defaultLabel;"
            >
              <span
                class="variant-swatch__color"
                style="background-color: {{ rec_color | strip | escape }};"
              ></span>
            </a>
          </li>
        {% endif %}
      </ul>
      <script>
        (function(){
            var list = document.currentScript.previousElementSibling;
            if (!list) return;
            list.classList.remove('is-hidden');
        })();
        </script>
    </div>

    <style>
        .product-variants-complementary__list.is-hidden {
        opacity: 0;
        }
      .product-variants-complementary__label {
        margin-bottom: 6px;
        font-size: 14px;
      }

      .product-variants-complementary__list {
        display: flex;
        gap: 6px;
        padding: 0;
        margin: 0;
        list-style: none;
        flex-wrap: wrap;
        opacity:1
      }

      .variant-swatch {
        display: inline-flex;
        padding: 2px;
        border: 1px solid transparent;
        border-radius: 4px;
        text-decoration: none;
      }

      .variant-swatch--active {
        border-color: black;
      }

      .variant-swatch__color {
        width: 24px;
        height: 24px;
        border-radius: 4px;
        display: block;
        border: 1px solid #d9d9d9;
        box-sizing: border-box;
      }
    </style>
  {% endif %}
</product-recommendations>