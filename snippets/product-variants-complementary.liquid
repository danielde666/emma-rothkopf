{% comment %}
  Products as Variants (Complementary Products as Color Swatches)
  Final version:
  - renders current + complementary swatches
  - sorts alphabetically in JS by color label
  - keeps row hidden until sorting is complete
  - updates label on hover/focus
{% endcomment %}

<product-recommendations
  class="product-variants-complementary"
  data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ block.settings.product_list_limit }}&intent=complementary"
>
  {%- assign current_color_raw = product.metafields.custom.product_color -%}
  {%- assign current_color = '' -%}
  {%- assign current_color_label = '' -%}
  {%- assign label_id = 'product-variants-color-label-' | append: section.id | append: '-' | append: block.id -%}
  {%- assign list_id = 'product-variants-list-' | append: section.id | append: '-' | append: block.id -%}

  {% if current_color_raw %}
    {% assign v = current_color_raw.value %}

    {% if v.color %}
      {% assign current_color = v.color %}
    {% endif %}

    {% if v.label %}
      {% assign current_color_label = v.label %}
    {% elsif v.handle %}
      {% assign current_color_label = v.handle %}
    {% endif %}
  {% endif %}

  {% if current_color != blank %}
    <div class="product-variants-complementary__inner" {{ block.shopify_attributes }}>
      <p class="product-variants-complementary__label">
        {{ block.settings.heading }}:
        <span
          id="{{ label_id }}"
          class="product-variants-complementary__label-value"
          data-default-label="{{ current_color_label | default: 'Select' | escape }}"
        >
          {{ current_color_label | default: 'Select' }}
        </span>
      </p>

      <ul
        id="{{ list_id }}"
        class="product-variants-complementary__list product-variants-complementary__list--hidden"
        role="list"
      >
        <li
          class="product-variants-complementary__item"
          data-color-label="{{ current_color_label | strip | escape }}"
          data-is-current="true"
        >
          <div
            class="variant-swatch variant-swatch--active"
            aria-label="{{ product.title }} — {{ current_color_label | default: 'Current color' | escape }}"
          >
            <span
              class="variant-swatch__color"
              style="background-color: {{ current_color | strip | escape }};"
            ></span>
          </div>
        </li>

        {% if recommendations.performed and recommendations.products_count > 0 %}
          {% for rec in recommendations.products %}
            {% unless rec.id == product.id %}
              {% assign color_raw = rec.metafields.custom.product_color %}
              {% assign color_value = '' %}
              {% assign color_label = '' %}

              {% if color_raw %}
                {% assign v = color_raw.value %}

                {% if v.color %}
                  {% assign color_value = v.color %}
                {% endif %}

                {% if v.label %}
                  {% assign color_label = v.label %}
                {% elsif v.handle %}
                  {% assign color_label = v.handle %}
                {% endif %}
              {% endif %}

              {% if color_value != blank and color_label != blank %}
                <li
                  class="product-variants-complementary__item"
                  data-color-label="{{ color_label | strip | escape }}"
                  data-is-current="false"
                >
                  <a
                    href="{{ rec.url }}"
                    class="variant-swatch"
                    data-color-label="{{ color_label | escape }}"
                    aria-label="{{ rec.title }} — {{ color_label | escape }}"
                    onmouseenter="document.getElementById('{{ label_id }}').textContent = this.dataset.colorLabel;"
                    onmouseleave="document.getElementById('{{ label_id }}').textContent = document.getElementById('{{ label_id }}').dataset.defaultLabel;"
                    onfocus="document.getElementById('{{ label_id }}').textContent = this.dataset.colorLabel;"
                    onblur="document.getElementById('{{ label_id }}').textContent = document.getElementById('{{ label_id }}').dataset.defaultLabel;"
                  >
                    <span
                      class="variant-swatch__color"
                      style="background-color: {{ color_value | strip | escape }};"
                    ></span>
                  </a>
                </li>
              {% endif %}
            {% endunless %}
          {% endfor %}
        {% endif %}
      </ul>
    </div>

    <style>
      .product-variants-complementary__label {
        margin-bottom: 6px;
        font-size: 14px;
      }

      .product-variants-complementary__list {
        display: flex;
        gap: 6px;
        padding: 0;
        margin: 0;
        list-style: none;
        flex-wrap: wrap;
      }

      .product-variants-complementary__list--hidden {
        visibility: hidden;
      }

      .variant-swatch {
        display: inline-flex;
        padding: 2px;
        border: 1px solid transparent;
        border-radius: 4px;
        text-decoration: none;
      }

      .variant-swatch--active {
        border-color: black;
      }

      .variant-swatch__color {
        width: 24px;
        height: 24px;
        border-radius: 4px;
        display: block;
        border: 1px solid #d9d9d9;
        box-sizing: border-box;
      }
    </style>

    <script>
      (function () {
        var list = document.getElementById('{{ list_id }}');
        if (!list) return;

        var items = Array.prototype.slice.call(
          list.querySelectorAll('.product-variants-complementary__item')
        );

        items.sort(function (a, b) {
          var aLabel = (a.dataset.colorLabel || '').toLowerCase().trim();
          var bLabel = (b.dataset.colorLabel || '').toLowerCase().trim();

          if (aLabel < bLabel) return -1;
          if (aLabel > bLabel) return 1;
          return 0;
        });

        items.forEach(function (item) {
          list.appendChild(item);
        });

        list.classList.remove('product-variants-complementary__list--hidden');
      })();
    </script>
  {% endif %}
</product-recommendations>